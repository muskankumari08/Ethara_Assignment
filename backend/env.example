# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=your-backend.up.railway.app,localhost,127.0.0.1

# Database (Railway Postgres plugin sets DATABASE_URL)
# DATABASE_URL=postgres://user:pass@host:port/dbname
# DATABASE_SSL_REQUIRE=true

# CORS — comma-separated frontend origins (no trailing slash)
CORS_ALLOWED_ORIGINS=https://your-frontend.up.railway.app

# Optional: trusted origins for CSRF (if you use session/cookie flows)
# CSRF_TRUSTED_ORIGINS=https://your-frontend.up.railway.app
